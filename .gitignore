# ---------------------------
# IDE and Tooling Junk
# ---------------------------

# IntelliJ / Android Studio / Xcode project files
*.iml
.idea/
.DS_Store
xcuserdata/

# Gradle and Kotlin build metadata
.gradle/
.kotlin/

# External Native Build artifacts
.externalNativeBuild/
.cxx/

# Local configuration not meant for sharing
local.properties

# ---------------------------
# Build Artifacts
# ---------------------------

# Common build folders (KMP, Android, iOS, Desktop)
**/build/
# Exception: keep actual source build folders if needed
!src/**/build/

# ---------------------------
# Xcode Noise
# ---------------------------

# Ignore entire .xcodeproj contents except for what’s versionable
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/

# Keep workspace metadata
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings

# ---------------------------
# Assets and Generated Files
# ---------------------------

# Android auto-generated icons
**/res/mipmap-*/
**/res/drawable/ic_launcher_*

# iOS auto-generated/placeholder assets (image files only)
**/*.appiconset/*.png
**/*.appiconset/*.jpg
**/Preview Content/
# Ignore personal/sensitive xcconfig overrides but keep the shared templates
**/Configuration/**
!iosApp/Configuration/
!iosApp/Configuration/Config.xcconfig
!iosApp/Configuration/Dev.xcconfig
!iosApp/Configuration/Staging.xcconfig
!iosApp/Configuration/Prod.xcconfig

# Unnecessary binaries (exclude intentional project screenshots)
*.png
!docs/screenshots/*.png

# ---------------------------
# Debug and Capture Files
# ---------------------------

captures/


# ---------------------------
# Firebase Config
# ---------------------------
**/google-services.json
**/GoogleService-Info.plist

# ---------------------------
# Out-of-repo workspace (business / strategy / investor / legal)
# Not for the engineering repo. Move /basil-ops to your own machine.
# ---------------------------
/basil-ops/
