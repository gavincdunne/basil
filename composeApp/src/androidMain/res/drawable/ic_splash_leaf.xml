<?xml version="1.0" encoding="utf-8"?>
<!--
    Basil leaf mark for the Android OS SplashScreen.
    Rendered on the sage-600 background — fill is white, veins are sage-800.
    Sized to 108dp (Android adaptive icon inner canvas) centred in the view.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Leaf body — teardrop centred in the 108dp canvas -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,14
            C40.5,22.5 28,38.5 28,52
            C28,65.5 40,75 54,75
            C68,75 80,65.5 80,52
            C80,38.5 67.5,22.5 54,14Z" />

    <!-- Central vein -->
    <path
        android:strokeColor="#27342B"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,75 L54,48" />

    <!-- Left secondary vein -->
    <path
        android:strokeColor="#27342B"
        android:strokeAlpha="0.7"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,66 C54,66 43,61 39,54" />

    <!-- Right secondary vein -->
    <path
        android:strokeColor="#27342B"
        android:strokeAlpha="0.7"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,58 C54,58 66,52 69,44" />

</vector>
